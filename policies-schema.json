{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "additional_array_item": {
      "properties": {
        "schema": {
          "$ref": "#/$defs/allowed_schemas/properties/array"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "schema": {
                "const": "array"
              }
            }
          },
          "then": {
            "$ref": "#/$defs/schemas/properties/array"
          }
        },
        {
          "if": {
            "properties": {
              "schema": {
                "const": "object"
              }
            }
          },
          "then": {
            "$ref": "#/$defs/schemas/properties/object"
          }
        },
        {
          "if": {
            "properties": {
              "schema": {
                "const": "string"
              }
            }
          },
          "then": {
            "$ref": "#/$defs/schemas/properties/string"
          }
        }
      ],
      "required": ["schema"],
      "unevaluatedProperties": false
    },
    "allowed_schemas": {
      "type": "object",
      "properties": {
        "array": {
          "enum": ["array", "boolean", "object", "string"]
        },
        "object": {
          "enum": ["array", "boolean", "enum", "heading", "object", "string"]
        },
        "policy": {
          "enum": ["array", "boolean", "enum", "object", "string"]
        }
      }
    },
    "browser_version": {
      "type": ["null", "string"],
      "pattern": "^[\\d]{2,3}\\.[\\d]{1,2}(\\.[\\d]{1,2})?$"
    },
    "key": {
      "type": "object",
      "properties": {
        "placeholder": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "oneOf": [
        {
          "properties": {
            "validations": {
              "type": "array",
              "items": {
                "const": "preference"
              },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "required": ["placeholder"]
        },
        {
          "required": ["value"]
        }
      ],
      "unevaluatedProperties": false
    },
    "schemas": {
      "type": "object",
      "properties": {
        "array": {
          "type": "object",
          "properties": {
            "items": {
              "properties": {
                "schema": {
                  "$ref": "#/$defs/allowed_schemas/properties/array"
                },
                "link": {
                  "type": "string"
                },
                "allow_empty_value": {
                  "type": "boolean"
                },
                "additions": {
                  "type": "object",
                  "properties": {
                    "prepend": {
                      "$ref": "#/$defs/additional_array_item"
                    },
                    "append": {
                      "$ref": "#/$defs/additional_array_item"
                    }
                  },
                  "minProperties": 1,
                  "unevaluatedProperties": false
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "schema": {
                        "const": "boolean"
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "options": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "name": {
                              "type": "string"
                            },
                            "label": {
                              "type": "string"
                            }
                          },
                          "required": ["name", "label"],
                          "unevaluatedProperties": false
                        },
                        "minItems": 1,
                        "uniqueItems": true
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "schema": {
                        "const": "object"
                      }
                    }
                  },
                  "then": {
                    "$ref": "#/$defs/schemas/properties/object"
                  }
                },
                {
                  "if": {
                    "properties": {
                      "schema": {
                        "const": "string"
                      }
                    }
                  },
                  "then": {
                    "$ref": "#/$defs/schemas/properties/string",
                    "properties": {
                      "join": {
                        "enum": [",", "|", " "]
                      }
                    }
                  }
                }
              ],
              "required": ["schema"],
              "unevaluatedProperties": false
            }
          },
          "required": ["items"]
        },
        "boolean": {
          "type": "object",
          "properties": {
            "inverse": {
              "type": "boolean"
            }
          }
        },
        "heading": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            }
          },
          "required": ["label"]
        },
        "enum": {
          "type": "object",
          "properties": {
            "sort_options": {
              "type": "boolean"
            },
            "default": {
              "type": ["boolean", "integer", "null", "string"]
            }
          },
          "oneOf": [
            {
              "properties": {
                "options": {
                  "type": "array",
                  "items": {
                    "properties": {
                      "label": {
                        "type": "string"
                      },
                      "value": {
                        "type": ["boolean", "integer", "null", "string"]
                      }
                    },
                    "required": ["label", "value"],
                    "additionalProperties": false
                  },
                  "minItems": 1,
                  "uniqueItems": true
                }
              },
              "required": ["options"]
            },
            {
              "properties": {
                "preset": {
                  "type": "string"
                }
              },
              "required": ["preset"]
            }
          ]
        },
        "object": {
          "type": "object",
          "properties": {
            "label": {
              "type": "string"
            },
            "key": {
              "$ref": "#/$defs/key"
            },
            "lockable": {
              "type": "boolean"
            },
            "properties": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "schema": {
                    "$ref": "#/$defs/allowed_schemas/properties/object"
                  },
                  "label": {
                    "type": "string"
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "properties": {
                        "schema": {
                          "const": "array"
                        }
                      }
                    },
                    "then": {
                      "$ref": "#/$defs/schemas/properties/array"
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "schema": {
                          "const": "enum"
                        }
                      }
                    },
                    "then": {
                      "$ref": "#/$defs/schemas/properties/enum"
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "schema": {
                          "const": "heading"
                        }
                      }
                    },
                    "then": {
                      "$ref": "#/$defs/schemas/properties/heading"
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "schema": {
                          "const": "object"
                        }
                      }
                    },
                    "then": {
                      "$ref": "#/$defs/schemas/properties/object"
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "schema": {
                          "const": "string"
                        }
                      }
                    },
                    "then": {
                      "$ref": "#/$defs/schemas/properties/string"
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "schema": {
                          "not": {
                            "const": "heading"
                          }
                        }
                      }
                    },
                    "then": {
                      "required": ["name"]
                    }
                  }
                ],
                "required": ["schema"],
                "unevaluatedProperties": false
              },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "required": ["properties"]
        },
        "string": {
          "type": "object",
          "properties": {
            "key": {
              "$ref": "#/$defs/key"
            },
            "textarea": {
              "type": "boolean"
            },
            "label": {
              "type": "string"
            },
            "placeholder": {
              "type": "string"
            },
            "minimum": {
              "type": "integer"
            },
            "maximum": {
              "type": "integer"
            },
            "validations": {
              "type": "array",
              "items": {
                "enum": ["json", "number", "required", "url"]
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "url_schemes": {
              "type": "array",
              "items": {
                "enum": ["data", "file", "http", "https", "javascript"]
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "regex": {
              "type": "object",
              "properties": {
                "pattern": {
                  "type": "string"
                },
                "error": {
                  "type": "string"
                }
              },
              "required": ["pattern", "error"]
            },
            "allow_empty_value": {
              "type": "boolean"
            },
            "output_filter": {
              "type": "string"
            }
          },
          "dependentSchemas": {
            "minimum": {
              "properties": {
                "validations": {
                  "contains": {
                    "const": "number"
                  }
                }
              },
              "required": ["validations"]
            },
            "maximum": {
              "properties": {
                "validations": {
                  "contains": {
                    "const": "number"
                  }
                }
              },
              "required": ["validations"]
            },
            "url_schemes": {
              "properties": {
                "validations": {
                  "contains": {
                    "const": "url"
                  }
                }
              },
              "required": ["validations"]
            }
          },
          "required": ["placeholder"]
        }
      }
    }
  },
  "type": "object",
  "properties": {
    "policies": {
      "type": "object",
      "patternProperties": {
        "\\w+": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "availability": {
              "type": "object",
              "properties": {
                "mainstream": {
                  "$ref": "#/$defs/browser_version"
                },
                "esr": {
                  "$ref": "#/$defs/browser_version"
                }
              },
              "required": ["mainstream", "esr"],
              "additionalProperties": false
            },
            "tags": {
              "type": "array",
              "items": {
                "enum": [
                  "authentication", "block-access", "bookmarks", "customization", "downloads", "features",
                  "network", "others", "printing", "privacy", "security", "updates-and-data", "website"
                ]
              },
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "deprecation": {
              "type": "string"
            },
            "note": {
              "type": "string"
            },
            "security_warning": {
              "type": "boolean"
            },
            "link": {
              "type": "string"
            },
            "schema": {
              "$ref": "#/$defs/allowed_schemas/properties/policy"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "schema": {
                    "const": "array"
                  }
                }
              },
              "then": {
                "$ref": "#/$defs/schemas/properties/array"
              }
            },
            {
              "if": {
                "properties": {
                  "schema": {
                    "const": "boolean"
                  }
                }
              },
              "then": {
                "$ref": "#/$defs/schemas/properties/boolean"
              }
            },
            {
              "if": {
                "properties": {
                  "schema": {
                    "const": "enum"
                  }
                }
              },
              "then": {
                "$ref": "#/$defs/schemas/properties/enum"
              }
            },
            {
              "if": {
                "properties": {
                  "schema": {
                    "const": "object"
                  }
                }
              },
              "then": {
                "$ref": "#/$defs/schemas/properties/object"
              }
            },
            {
              "if": {
                "properties": {
                  "schema": {
                    "const": "string"
                  }
                }
              },
              "then": {
                "$ref": "#/$defs/schemas/properties/string"
              }
            }
          ],
          "required": ["availability", "schema", "tags"],
          "unevaluatedProperties": false
        }
      }
    },
    "preferences": {
      "type": "object",
      "properties": {
        "allowed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "disallowed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "required": ["allowed", "disallowed"],
      "unevaluatedProperties": false
    },
    "presets": {
      "type": "object",
      "patternProperties": {
        "\\w+": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": ["boolean", "null", "string"]
              }
            },
            "required": ["label", "value"],
            "unevaluatedProperties": false
          },
          "uniqueItems": true
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "required": ["policies", "preferences", "presets", "tags"],
  "additionalProperties": false
}
