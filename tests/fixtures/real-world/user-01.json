{
  "policies": {
    "Certificates": {
      "ImportEnterpriseRoots": true
    },
    "DNSOverHTTPS": {
      "Enabled": true
    },
    "DefaultDownloadDirectory": "D:\\Downloads",
    "DisableAppUpdate": true,
    "DisableFeedbackCommands": true,
    "DisableFirefoxStudies": true,
    "DisableProfileImport": true,
    "DisableSystemAddonUpdate": true,
    "DisableTelemetry": true,
    "DontCheckDefaultBrowser": true,
    "EnableTrackingProtection": {
      "Cryptomining": true,
      "Fingerprinting": true,
      "Value": true
    },
    "ExtensionSettings": {
      "*": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "installation_mode": "blocked"
      },
      "amazon@search.mozilla.org": {
        "installation_mode": "blocked"
      },
      "enterprise-policy-generator@agenedia.com": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/enterprise-policy-generator/latest.xpi",
        "installation_mode": "normal_installed"
      },
      "idcac-pub@guus.ninja": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/istilldontcareaboutcookies/latest.xpi",
        "installation_mode": "normal_installed"
      },
      "printedit-we@DW-dev": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/print-edit-we/latest.xpi",
        "installation_mode": "normal_installed"
      },
      "uBlock0@raymondhill.net": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/ublock-origin/latest.xpi",
        "installation_mode": "normal_installed"
      },
      "{0d20e3ac-ee5b-4db9-bd3f-8ed745f569a7}": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/view-image-context-menu-item/latest.xpi",
        "installation_mode": "normal_installed"
      },
      "{bd97f89b-17ba-4539-9fec-06852d07f917}": {
        "blocked_install_message": "This add-on can not be installed. Please ask your administrator.",
        "install_url": "https://addons.mozilla.org/firefox/downloads/latest/checkmarks-web-ext/latest.xpi",
        "installation_mode": "normal_installed"
      }
    },
    "ExtensionUpdate": true,
    "FirefoxHome": {
      "Highlights": false,
      "Pocket": false,
      "Search": true,
      "TopSites": false
    },
    "Homepage": {
      "StartPage": "homepage",
      "URL": "https://www.google.com/#cns=0"
    },
    "NoDefaultBookmarks": true,
    "OfferToSaveLoginsDefault": false,
    "OverrideFirstRunPage": "",
    "OverridePostUpdatePage": "",
    "PopupBlocking": {
      "Default": true,
      "Locked": true
    },
    "Preferences": {
      "browser.search.update": {
        "Status": "locked",
        "Type": "boolean",
        "Value": false
      },
      "dom.disable_window_flip": {
        "Status": "locked",
        "Type": "boolean",
        "Value": true
      },
      "dom.disable_window_move_resize": {
        "Status": "locked",
        "Type": "boolean",
        "Value": true
      },
      "dom.event.contextmenu.enabled": {
        "Status": "locked",
        "Type": "boolean",
        "Value": false
      },
      "media.gmp-gmpopenh264.enabled": {
        "Status": "locked",
        "Type": "boolean",
        "Value": true
      }
    },
    "PrimaryPassword": false,
    "PromptForDownloadLocation": false,
    "SSLVersionMax": "tls1.3",
    "SSLVersionMin": "tls1",
    "SanitizeOnShutdown": {
      "Cache": true,
      "Cookies": true,
      "FormData": true,
      "History": true,
      "Locked": false,
      "Sessions": true,
      "SiteSettings": false
    },
    "SearchBar": "separate",
    "SearchEngines": {
      "Add": [
        {
          "Alias": "@wikipediade",
          "Description": "Wikipedia, die freie Enzyklopädie",
          "IconURL": "https://de.wikipedia.org/favicon.ico",
          "Method": "GET",
          "Name": "Wikipedia (de)",
          "SuggestURLTemplate": "https://de.wikipedia.org/w/api.php?action=opensearch&search={searchTerms}",
          "URLTemplate": "https://de.wikipedia.org/wiki/Special:Search?search={searchTerms}&sourceid=Mozilla-search"
        },
        {
          "Alias": "@wikipedia",
          "Description": "Wikipedia, the Free Encyclopedia",
          "IconURL": "https://en.wikipedia.org/favicon.ico",
          "Method": "GET",
          "Name": "Wikipedia (en)",
          "SuggestURLTemplate": "https://en.wikipedia.org/w/api.php?action=opensearch&search={searchTerms}",
          "URLTemplate": "https://en.wikipedia.org/wiki/Special:Search?search={searchTerms}&sourceid=Mozilla-search"
        },
        {
          "Alias": "@startpage",
          "Description": "The world's most private search engine",
          "IconURL": "data:image/png;base64,",
          "Method": "GET",
          "Name": "StartPage",
          "SuggestURLTemplate": "https://www.startpage.com/sp/search?query={searchTerms}",
          "URLTemplate": "https://www.startpage.com/sp/search?query={searchTerms}"
        }
      ],
      "Default": "Google",
      "PreventInstalls": true,
      "Remove": [
        "DuckDuckGo",
        "DuckDuckGo Lite",
        "eBay",
        "LEO Eng-Deu",
        "Ecosia",
        "MetaGer",
        "SearXNG"
      ]
    },
    "TranslateEnabled": false
  }
}
