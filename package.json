{
  "name": "enterprise-policy-generator",
  "version": "9.0.0",
  "description": "Generates Enterprise Policies for Firefox.",
  "author": {
    "name": "Sören Hentzschel",
    "email": "kontakt@agenedia.com",
    "url": "https://firefox.agenedia.com"
  },
  "homepage": "https://www.soeren-hentzschel.at/firefox-webextensions/enterprise-policy-generator/?utm_campaign=webext&utm_term=enterprise",
  "bugs": {
    "email": "kontakt@agenedia.com"
  },
  "license": "MPL 2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cadeyrn/enterprise-policy-generator/"
  },
  "private": true,
  "browserslist": [
    "Firefox >= 140"
  ],
  "devDependencies": {
    "@eslint/json": "2.0.0",
    "@html-eslint/eslint-plugin": "0.61.0",
    "@sourcemeta/jsonschema": "15.6.3",
    "@stylistic/eslint-plugin": "5.10.0",
    "eslint": "10.4.1",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-xss": "0.1.12",
    "stylelint": "17.11.1",
    "stylelint-order": "8.1.1",
    "web-ext": "10.3.0"
  },
  "scripts": {
    "build": "web-ext build --source-dir ./src --artifacts-dir ./dist --filename {name}-{version}.xpi --overwrite-dest",
    "lint": "node lint.mjs",
    "lint:css": "stylelint ./src/css/**/*.css",
    "lint:html": "eslint ./src/html/**/*.html",
    "lint:js": "eslint ./src/js/**/*.js ./src/_locales/**/*.json",
    "lint:policies-schema": "jsonschema lint policies-schema.json --exclude top_level_title --exclude top_level_description --exclude top_level_examples --exclude unnecessary_allof_wrapper",
    "lint:policies": "jsonschema validate policies-schema.json src/policies/*.json",
    "lint:web-ext": "web-ext lint --source-dir ./src",
    "run:nightly": "web-ext run --source-dir ./src --firefox=nightly",
    "run:beta": "web-ext run --source-dir ./src --firefox=beta",
    "run:stable": "web-ext run --source-dir ./src --firefox=firefox",
    "run:esr": "web-ext run --source-dir ./src --firefox=\"/Applications/Firefox ESR.app\""
  }
}
